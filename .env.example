# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your real values
#   source .env   (or make reads it automatically)

# ── GCP ──────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=${GCP_PROJECT_ID}-mlops-data
REGION=asia-southeast1

# ── DVC remote (set locally so .dvc/config stays generic) ───────────
# Run: dvc remote modify --local gcs url gs://${GCS_BUCKET}/dvc-cache

# ── MLflow ───────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
# For GKE: MLFLOW_TRACKING_URI=http://mlflow.mlops.svc.cluster.local:5000

# ── Kaggle (for data download) ───────────────────────────────────────
# Place ~/.kaggle/kaggle.json  (chmod 600)
# KAGGLE_USERNAME=your-username
# KAGGLE_KEY=your-api-key
